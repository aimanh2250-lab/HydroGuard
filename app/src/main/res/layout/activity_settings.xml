<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".SettingsActivity">

    <!-- ================= MAIN CONTENT ================= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ✅ BACKGROUND IMAGE -->
        <ImageView
            android:id="@+id/ivAnimatedBg"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:alpha="0.95"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_motion_gradient"
            android:contentDescription="@null"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ✅ Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:title="Settings"
            app:navigationIcon="@drawable/ic_menu"
            app:titleTextColor="@color/hg_brandNavy"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ================= Scrollable Content ================= -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/settingsScroll"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:clipToPadding="false"
            android:paddingBottom="14dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="18dp">

                <!-- ================= Header ================= -->
                <LinearLayout
                    android:id="@+id/headerRow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_settings"
                        android:contentDescription="Settings"
                        app:tint="@color/hg_primary"
                        android:layout_marginEnd="10dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/settingsTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Profile"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/hg_brandNavy"
                            android:letterSpacing="0.02" />

                        <TextView
                            android:id="@+id/settingsSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manage profile, goals and account"
                            android:textSize="14sp"
                            android:textColor="@color/hg_muted"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ================= PROFILE CARD ================= -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/profileCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="@color/hg_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/hg_outline"
                    app:strokeWidth="1dp"
                    app:layout_constraintTop_toBottomOf="@id/headerRow"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:src="@drawable/ic_user"
                                android:contentDescription="Profile"
                                app:tint="@color/hg_muted"
                                android:layout_marginEnd="12dp"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvProfileName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="HydroGuard User"
                                    android:textStyle="bold"
                                    android:textSize="16sp"
                                    android:textColor="@color/hg_brandNavy" />

                                <TextView
                                    android:id="@+id/tvProfileEmail"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="user@email.com"
                                    android:textSize="13sp"
                                    android:textColor="@color/hg_muted"
                                    android:layout_marginTop="2dp"/>

                                <TextView
                                    android:id="@+id/tvProfilePhone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Phone not set"
                                    android:textSize="13sp"
                                    android:textColor="@color/hg_muted"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="User ID"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/hg_onSurface"
                            android:layout_marginTop="12dp"/>

                        <TextView
                            android:id="@+id/tvProfileUid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="UID"
                            android:textSize="12sp"
                            android:textColor="@color/hg_muted"
                            android:layout_marginTop="4dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEditProfile"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="14dp"
                            android:text="Edit Profile"
                            android:textAllCaps="false"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:cornerRadius="14dp"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:strokeColor="@color/hg_outline"
                            app:strokeWidth="1dp"
                            android:textColor="@color/hg_onSurface" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ================= Usage Goals Card ================= -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/goalsCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="@color/hg_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/hg_outline"
                    app:strokeWidth="1dp"
                    app:layout_constraintTop_toBottomOf="@id/profileCard"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_target"
                                android:contentDescription="Goals"
                                app:tint="@color/hg_muted"
                                android:layout_marginEnd="10dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Usage Goals"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="@color/hg_brandNavy" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Set targets to receive alerts at 50%, 80%, 100% and abnormal usage."
                            android:textSize="13sp"
                            android:textColor="@color/hg_muted"
                            android:layout_marginTop="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daily Goal (L)"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:textColor="@color/hg_onSurface"
                            android:layout_marginTop="14dp"/>

                        <EditText
                            android:id="@+id/dailyGoalInput"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/input_field"
                            android:padding="12dp"
                            android:inputType="numberDecimal"
                            android:digits="0123456789."
                            android:hint="e.g. 5"
                            android:textSize="15sp"
                            android:textColor="@color/hg_onSurface"
                            android:textColorHint="@color/hg_muted" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monthly Goal (L)"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:textColor="@color/hg_onSurface"
                            android:layout_marginTop="14dp"/>

                        <EditText
                            android:id="@+id/monthlyGoalInput"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/input_field"
                            android:padding="12dp"
                            android:inputType="numberDecimal"
                            android:digits="0123456789."
                            android:hint="e.g. 150"
                            android:textSize="15sp"
                            android:textColor="@color/hg_onSurface"
                            android:textColorHint="@color/hg_muted" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/saveGoalsButton"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="14dp"
                            android:text="Save Usage Goals"
                            android:textAllCaps="false"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:cornerRadius="14dp"
                            app:backgroundTint="@color/hg_primary"
                            android:textColor="@color/hg_onPrimary" />

                        <TextView
                            android:id="@+id/goalsNoteText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Abnormal usage thresholds: daily ≈ goal × 2, monthly ≈ goal × 3."
                            android:textSize="12sp"
                            android:textColor="@color/hg_muted"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ================= Account Card ================= -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/accountCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="@color/hg_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/hg_outline"
                    app:strokeWidth="1dp"
                    app:layout_constraintTop_toBottomOf="@id/goalsCard"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_user"
                                android:contentDescription="Account"
                                app:tint="@color/hg_muted"
                                android:layout_marginEnd="10dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Account"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="@color/hg_brandNavy" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/accountSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Help and session controls"
                            android:textSize="13sp"
                            android:textColor="@color/hg_muted"
                            android:layout_marginTop="6dp"/>

                        <!-- ✅ Help & FAQ button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/faqButton"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="14dp"
                            android:text="Help and FAQ"
                            android:textAllCaps="false"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/ic_help"
                            app:iconPadding="10dp"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:strokeColor="@color/hg_outline"
                            app:strokeWidth="1dp"
                            android:textColor="@color/hg_onSurface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/logoutButton"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="10dp"
                            android:text="Logout"
                            android:textAllCaps="false"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/ic_logout"
                            app:iconPadding="10dp"
                            app:backgroundTint="@color/hg_error"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Spacer -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="18dp"
                    app:layout_constraintTop_toBottomOf="@id/accountCard"
                    app:layout_constraintBottom_toBottomOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Drawer menu -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="@color/hg_surface"
        app:menu="@menu/drawer_menu"
        app:itemIconTint="@color/hg_onSurface"
        app:itemTextColor="@color/hg_onSurface"
        app:itemBackground="@drawable/drawer_item_bg" />

</androidx.drawerlayout.widget.DrawerLayout>
