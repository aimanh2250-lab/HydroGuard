<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardBackgroundColor="@color/hg_surface"
    app:cardCornerRadius="18dp"
    app:cardElevation="8dp"
    app:strokeColor="@color/hg_outline"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Date -->
        <TextView
            android:id="@+id/billingDateText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="2026-01-10"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/hg_brandNavy"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/chipCost"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintHorizontal_bias="0" />

        <!-- Cost chip (right) -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipCost"
            style="@style/Widget.Material3.Chip.Assist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RM 0.00"
            android:textStyle="bold"
            app:chipBackgroundColor="@color/hg_secondaryContainer"
            android:textColor="@color/hg_brandNavy"
            app:chipStrokeColor="@color/hg_outline"
            app:chipStrokeWidth="1dp"
            app:chipIcon="@drawable/ic_billing"
            app:chipIconVisible="true"
            app:iconStartPadding="8dp"
            app:textStartPadding="6dp"
            app:textEndPadding="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Tap line -->
        <TextView
            android:id="@+id/billingTapText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tap: 0.0 L"
            android:textSize="13sp"
            android:textColor="@color/hg_onSurface"
            android:alpha="0.9"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/billingDateText"/>

        <!-- Shower line -->
        <TextView
            android:id="@+id/billingShowerText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Shower: 0.0 L"
            android:textSize="13sp"
            android:textColor="@color/hg_onSurface"
            android:alpha="0.9"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/billingTapText"/>

        <!-- Optional: Uncat line (hidden if not needed) -->
        <TextView
            android:id="@+id/billingUncatText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Uncategorized: 0.0 L"
            android:textSize="13sp"
            android:textColor="@color/hg_onSurface"
            android:alpha="0.85"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/billingShowerText"/>

        <!-- Total (small) -->
        <TextView
            android:id="@+id/billingTotalText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Total: 0.0 L"
            android:textSize="12sp"
            android:textColor="@color/hg_muted"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/billingUncatText"/>

        <!-- Block tier -->
        <TextView
            android:id="@+id/billingBlockText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Block 1 (RM0.57)"
            android:textSize="12sp"
            android:textColor="@color/hg_muted"
            android:layout_marginTop="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/billingTotalText"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
