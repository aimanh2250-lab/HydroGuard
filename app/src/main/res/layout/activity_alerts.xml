<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".AlertsActivity">

    <!-- ================= MAIN CONTENT ================= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ✅ Background (same as Dashboard / Insights / Billing) -->
        <ImageView
            android:id="@+id/ivAnimatedBg"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:alpha="0.95"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_motion_gradient"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Toolbar (required by BaseDrawerActivity) -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:title="Alerts"
            app:navigationIcon="@drawable/ic_menu"
            android:textColor="@color/hg_brandNavy"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ================= Header (Billing/Insights style) ================= -->
        <LinearLayout
            android:id="@+id/headerRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="22dp"
            android:layout_marginEnd="22dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_alert_outline"
                android:contentDescription="Alerts"
                app:tint="@color/hg_accentTeal"
                android:layout_marginEnd="10dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/alertsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notifications"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/hg_sectionTitle"
                    android:letterSpacing="0.03" />

                <TextView
                    android:id="@+id/alertsSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Latest system and leak alerts"
                    android:textColor="@color/hg_muted"
                    android:alpha="0.85"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/alertsRecycler"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            app:layout_constraintTop_toBottomOf="@id/headerRow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ✅ Empty State (modern UX, same theme) -->
        <LinearLayout
            android:id="@+id/tvEmpty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:padding="24dp"
            app:layout_constraintTop_toBottomOf="@id/headerRow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/ivEmptyIcon"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/ic_alert_outline"
                app:tint="@color/hg_muted"
                android:contentDescription="No alerts" />

            <TextView
                android:id="@+id/tvEmptyTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Alerts"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/hg_brandNavy"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/tvEmptySubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You're all good. No unusual water activity detected."
                android:textSize="14sp"
                android:textColor="@color/hg_muted"
                android:gravity="center"
                android:layout_marginTop="6dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Drawer menu -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"

        android:background="@color/hg_surface"
        app:menu="@menu/drawer_menu"
        app:itemIconTint="@color/hg_onSurface"
        app:itemTextColor="@color/hg_onSurface"
        app:itemBackground="@drawable/drawer_item_bg" />

</androidx.drawerlayout.widget.DrawerLayout>
