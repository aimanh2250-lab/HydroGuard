<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <com.google.android.material.card.MaterialCardView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:strokeColor="@color/hg_outline"
        app:strokeWidth="1dp"
        app:cardBackgroundColor="@color/hg_surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp">

            <TextView
                android:id="@+id/dateText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2025-11-20"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/hg_brandNavy"/>

            <com.google.android.material.chip.Chip
                style="@style/Widget.Material3.Chip.Assist"
                android:id="@+id/usageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="120.5 L"
                android:textStyle="bold"
                android:textColor="@color/hg_primary"
                app:chipBackgroundColor="@color/hg_primaryContainer"
                app:chipStrokeColor="@color/hg_outline"
                app:chipStrokeWidth="1dp"/>
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>


</androidx.cardview.widget.CardView>
