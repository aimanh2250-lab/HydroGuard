<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="18dp"
    app:cardElevation="6dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/hg_outline"
    app:cardBackgroundColor="@color/hg_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="14dp">

        <!-- Row 1: Name + Status pill -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/sensorNameText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tap"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/hg_onSurface"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/sensorStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:text="NORMAL"
                android:textAllCaps="true"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/hg_onSurface"
                android:background="@drawable/bg_status_pill_normal"/>
        </LinearLayout>

        <!-- Location -->
        <TextView
            android:id="@+id/sensorLocationText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Location: -"
            android:textSize="13sp"
            android:textColor="@color/hg_muted"
            android:layout_marginTop="4dp"
            android:maxLines="1"
            android:ellipsize="end"/>

        <!-- Category chip row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <!-- internal only (hidden by adapter) -->
            <TextView
                android:id="@+id/sensorLineText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:text="L1"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/sensorCategoryText"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap"
                android:textStyle="bold"
                android:textColor="@color/hg_secondary"
                app:chipBackgroundColor="@color/hg_secondaryContainer"
                app:chipStrokeColor="@color/hg_outline"
                app:chipStrokeWidth="1dp"
                app:chipIconVisible="false"
                app:ensureMinTouchTargetSize="true"
                app:iconStartPadding="8dp"
                app:textStartPadding="8dp"
                app:textEndPadding="10dp"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/hg_outline"
            android:alpha="0.40"/>

        <!-- Flow + Usage -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/sensorFlowText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Flow: 0.00 L/min"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/hg_primary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/sensorUsageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today: 0.00 L • Total: 0.00 L"
                android:textSize="13sp"
                android:textColor="@color/hg_muted"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Valve Button (Material 3; colors overridden by adapter) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnValveAction"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:minHeight="48dp"
            android:text="OPEN VALVE"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:stateListAnimator="@null"
            android:textColor="@color/hg_onSurface"
            app:iconTint="@color/hg_onSurface"
            app:strokeColor="@color/hg_outline"
            app:strokeWidth="1dp"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconSize="20dp"/>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
