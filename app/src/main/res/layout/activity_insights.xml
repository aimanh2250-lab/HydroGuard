<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".InsightsActivity">

    <!-- ================= MAIN CONTENT ================= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ✅ Background Image (same as Dashboard / Alerts / Billing) -->
        <ImageView
            android:id="@+id/ivAnimatedBg"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:alpha="0.95"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_motion_gradient"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:title="Insights"
            app:navigationIcon="@drawable/ic_menu"
            app:titleTextColor="@color/hg_brandNavy"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Scroll content -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:paddingBottom="14dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="18dp">

                <!-- ================= Header ================= -->
                <LinearLayout
                    android:id="@+id/headerRow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="Insights"
                        android:src="@drawable/ic_insights"
                        app:tint="@color/hg_primary" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monitoring"
                            android:textColor="@color/hg_brandNavy"
                            android:letterSpacing="0.02"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Month"
                            android:textColor="@color/hg_muted"
                            android:textSize="14sp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- ================= KPI Card ================= -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/kpiCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="@color/hg_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/hg_outline"
                    app:strokeWidth="1dp"
                    app:layout_constraintTop_toBottomOf="@id/headerRow"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Key Metrics"
                            android:textColor="@color/hg_onSurface"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/kpiSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Summary for this month based on historyDaily"
                            android:textColor="@color/hg_muted"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">

                            <!-- Total -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/boxTotal"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="@color/hg_primaryContainer"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toStartOf="@id/boxAvg"
                                app:layout_constraintWidth_percent="0.49">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="14dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Total"
                                        android:textColor="@color/hg_muted"
                                        android:textSize="12sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tvTotalMonth"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="6dp"
                                        android:text="0.0 L"
                                        android:textColor="@color/hg_primary"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Avg/day -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/boxAvg"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="@color/hg_field_bg"
                                app:strokeColor="@color/hg_outline"
                                app:strokeWidth="1dp"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintStart_toEndOf="@id/boxTotal"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintWidth_percent="0.49">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="14dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Avg / day"
                                        android:textColor="@color/hg_muted"
                                        android:textSize="12sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tvAvgDaily"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="6dp"
                                        android:text="0.0 L/day"
                                        android:textColor="@color/hg_onSurface"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Highest day -->
                            <TextView
                                android:id="@+id/tvHighestDay"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="Highest day: -"
                                android:textColor="@color/hg_onSurface"
                                android:textSize="14sp"
                                app:layout_constraintTop_toBottomOf="@id/boxTotal"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent" />

                            <!-- Projected -->
                            <TextView
                                android:id="@+id/tvProjectedMonth"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Projected: 0.0 L"
                                android:textColor="@color/hg_onSurface"
                                android:textSize="14sp"
                                app:layout_constraintTop_toBottomOf="@id/tvHighestDay"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent" />

                            <!-- Estimated bill (chip) -->
                            <com.google.android.material.chip.Chip
                                android:id="@+id/tvEstimatedBill"
                                style="@style/Widget.Material3.Chip.Assist"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="Estimated bill: RM 0.00"
                                android:textColor="@color/hg_onSurface"
                                android:textStyle="bold"
                                app:chipBackgroundColor="@android:color/white"
                                app:chipStrokeColor="@color/hg_outline"
                                app:chipStrokeWidth="1dp"
                                app:chipIcon="@drawable/ic_billing"
                                app:chipIconVisible="true"
                                app:layout_constraintTop_toBottomOf="@id/tvProjectedMonth"
                                app:layout_constraintStart_toStartOf="parent" />

                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ================= Top Categories ================= -->
                <TextView
                    android:id="@+id/topCatTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="16dp"
                    android:text="Top Categories (This Month)"
                    android:textColor="@color/hg_onSurface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/kpiCard"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/topCatSubtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="4dp"
                    android:text="Shower vs Tap usage ranking"
                    android:textColor="@color/hg_muted"
                    android:textSize="13sp"
                    app:layout_constraintTop_toBottomOf="@id/topCatTitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/topCatCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/hg_outline"
                    app:strokeWidth="1dp"
                    app:layout_constraintTop_toBottomOf="@id/topCatSubtitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTopCategories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:padding="12dp" />
                </com.google.android.material.card.MaterialCardView>

                <!-- ================= Tips Card ================= -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tipsCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/hg_outline"
                    app:strokeWidth="1dp"
                    app:layout_constraintTop_toBottomOf="@id/topCatCard"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_marginEnd="10dp"
                                android:contentDescription="Tips"
                                android:src="@drawable/ic_alert_outline"
                                app:tint="@color/hg_secondary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Conservation Tips"
                                android:textColor="@color/hg_onSurface"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvTips"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:alpha="0.88"
                            android:lineSpacingExtra="4dp"
                            android:text="• Tips will appear here after usage is recorded."
                            android:textColor="@color/hg_onSurface"
                            android:textSize="14sp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ================= Charts Section Title ================= -->
                <TextView
                    android:id="@+id/chartsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="16dp"
                    android:text="Trends"
                    android:textColor="@color/hg_onSurface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/tipsCard"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/chartsSubtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="4dp"
                    android:text="Usage visualization from historyDaily"
                    android:textColor="@color/hg_muted"
                    android:textSize="13sp"
                    app:layout_constraintTop_toBottomOf="@id/chartsTitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Last 7 Days -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLast7"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/hg_outline"
                    app:strokeWidth="1dp"
                    app:layout_constraintTop_toBottomOf="@id/chartsSubtitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Last 7 Days"
                            android:textColor="@color/hg_onSurface"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/subLast7"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Daily liters (total)"
                            android:textColor="@color/hg_muted"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />

                        <com.github.mikephil.charting.charts.BarChart
                            android:id="@+id/chartLast7Days"
                            android:layout_width="match_parent"
                            android:layout_height="240dp"
                            android:layout_marginTop="10dp"
                            android:paddingBottom="10dp"
                            android:background="@android:color/transparent"
                            android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Peak Hours Today -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHourlyToday"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/hg_outline"
                    app:strokeWidth="1dp"
                    app:layout_constraintTop_toBottomOf="@id/cardLast7"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Peak Hours (Today)"
                            android:textColor="@color/hg_onSurface"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/subHourly"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Hourly total liters (00–23)"
                            android:textColor="@color/hg_muted"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />

                        <com.github.mikephil.charting.charts.BarChart
                            android:id="@+id/chartHourlyToday"
                            android:layout_width="match_parent"
                            android:layout_height="240dp"
                            android:layout_marginTop="10dp"
                            android:paddingBottom="10dp"
                            android:background="@android:color/transparent"
                            android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Weekly Trend -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWeekly"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="18dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/hg_outline"
                    app:strokeWidth="1dp"
                    app:layout_constraintTop_toBottomOf="@id/cardHourlyToday"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Weekly Trend"
                            android:textColor="@color/hg_onSurface"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/subWeekly"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Daily average pattern (line chart)"
                            android:textColor="@color/hg_muted"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartWeekly"
                            android:layout_width="match_parent"
                            android:layout_height="260dp"
                            android:layout_marginTop="10dp"
                            android:paddingBottom="10dp"
                            android:background="@android:color/transparent"
                            android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Drawer menu -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"

        android:background="@color/hg_surface"
        app:menu="@menu/drawer_menu"
        app:itemIconTint="@color/hg_onSurface"
        app:itemTextColor="@color/hg_onSurface"
        app:itemBackground="@drawable/drawer_item_bg" />

</androidx.drawerlayout.widget.DrawerLayout>
