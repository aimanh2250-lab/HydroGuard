<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/hg_outline"
    app:cardBackgroundColor="@android:color/white">

    <!-- Row layout so we can place a severity bar on the left -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Severity color bar (set by adapter) -->
        <View
            android:id="@+id/severityBar"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="14dp"
            android:background="@color/hg_outline" />

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- 🔴 Alert Chip (TOP) -->
            <com.google.android.material.chip.Chip
                android:id="@+id/alertTag"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIMIT • HG001 • Tap"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"
                app:chipBackgroundColor="@color/hg_primaryContainer"
                app:chipStrokeColor="@color/hg_outline"
                app:chipStrokeWidth="1dp"
                app:chipIcon="@drawable/ic_alert"
                app:chipIconVisible="true"
                app:iconStartPadding="8dp"
                app:textStartPadding="6dp"
                app:textEndPadding="10dp" />

            <!-- 🟢 Title -->
            <TextView
                android:id="@+id/alertTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Daily usage 50%"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/hg_brandNavy"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Meta -->
            <TextView
                android:id="@+id/alertMetaText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap • HG001"
                android:textSize="12sp"
                android:textColor="@color/hg_muted"
                android:layout_marginTop="4dp" />

            <!-- Details -->
            <TextView
                android:id="@+id/alertDetailsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today: 30.9 L (Goal: 40.0 L)"
                android:textSize="14sp"
                android:textColor="@color/hg_onSurface"
                android:alpha="0.85"
                android:layout_marginTop="8dp" />

            <!-- Datetime -->
            <TextView
                android:id="@+id/alertDateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026-02-06 05:37"
                android:textSize="13sp"
                android:textColor="@color/hg_muted"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </LinearLayout>


</com.google.android.material.card.MaterialCardView>