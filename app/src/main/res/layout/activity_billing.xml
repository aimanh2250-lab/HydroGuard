<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".BillingActivity">

    <!-- ================= MAIN CONTENT ================= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ✅ Background Image -->
        <ImageView
            android:id="@+id/ivAnimatedBg"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:alpha="0.95"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_motion_gradient"
            android:contentDescription="@null"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:title="Billing"
            app:navigationIcon="@drawable/ic_menu"
            app:titleTextColor="@color/hg_onSurface"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Scrollable area -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/billingScroll"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:clipToPadding="false"
            android:paddingBottom="14dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/contentLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="18dp">

                <!-- ================= Header ================= -->
                <LinearLayout
                    android:id="@+id/headerRow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_billing"
                        android:contentDescription="Billing"
                        app:tint="@color/hg_primary"
                        android:layout_marginEnd="10dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/billingTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Payment"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/hg_brandNavy" />

                        <TextView
                            android:id="@+id/monthTitleText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="January 2026"
                            android:textSize="14sp"
                            android:textColor="@color/hg_muted"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ================= Summary Card ================= -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/summaryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/hg_outline"
                    app:strokeWidth="1dp"
                    app:layout_constraintTop_toBottomOf="@id/headerRow"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/currentUsageText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Tap: 0.0 L\nShower: 0.0 L"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/hg_accentTeal"
                            android:lineSpacingExtra="4dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/currentCostText"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RM 0.00"
                            android:textStyle="bold"
                            app:chipBackgroundColor="@color/hg_secondaryContainer"
                            android:textColor="@color/hg_brandNavy"
                            app:chipStrokeColor="@color/hg_outline"
                            app:chipStrokeWidth="1dp"
                            app:chipIcon="@drawable/ic_billing"
                            app:chipIconVisible="true"
                            android:layout_marginTop="10dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/paymentStatusChip"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UNPAID ⏳"
                            android:textStyle="bold"
                            app:chipBackgroundColor="@color/hg_warningContainer"
                            android:textColor="@color/hg_warning"
                            app:chipStrokeColor="@color/hg_outline"
                            app:chipStrokeWidth="1dp"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:id="@+id/lastMonthSummaryText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="December 2025\nTap: 0.0 L | Shower: 0.0 L\nTotal: 0.0 L (RM 0.00)"
                            android:textSize="13sp"
                            android:textColor="@color/hg_muted"
                            android:lineSpacingExtra="3dp"
                            android:layout_marginTop="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPayNow"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Pay Now"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:layout_marginTop="14dp"
                            app:icon="@drawable/ic_billing"
                            app:iconPadding="10dp"
                            app:cornerRadius="16dp"
                            app:backgroundTint="@color/hg_primary"
                            android:textColor="@color/hg_onPrimary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ================= Chart Card ================= -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/chartCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/hg_outline"
                    app:strokeWidth="1dp"
                    app:layout_constraintTop_toBottomOf="@id/summaryCard"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/chartTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Monthly Usage Trend"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="@color/hg_brandNavy"
                            android:letterSpacing="0.02"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/chartSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Daily liters (auto-calculated from historyDaily)"
                            android:textSize="13sp"
                            android:textColor="@color/hg_muted"
                            android:layout_marginBottom="10dp"/>

                        <com.github.mikephil.charting.charts.BarChart
                            android:id="@+id/billingChart"
                            android:layout_width="match_parent"
                            android:layout_height="240dp"
                            android:background="@android:color/transparent" />
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ================= Daily Breakdown Title ================= -->
                <TextView
                    android:id="@+id/dailyBreakdownTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Daily Breakdown"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/hg_brandNavy"
                    android:letterSpacing="0.02"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="14dp"
                    app:layout_constraintTop_toBottomOf="@id/chartCard"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/dailyBreakdownSubtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Your usage per day for this month"
                    android:textSize="13sp"
                    android:textColor="@color/hg_muted"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/dailyBreakdownTitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- ✅ Daily list -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/billingRecycler"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="10dp"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    app:layout_constraintTop_toBottomOf="@id/dailyBreakdownSubtitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- ================= Payment History ================= -->
                <TextView
                    android:id="@+id/paymentHistoryTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Payment History"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/hg_brandNavy"
                    android:letterSpacing="0.02"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="14dp"
                    app:layout_constraintTop_toBottomOf="@id/billingRecycler"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/paymentHistorySubtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Previous payments and status"
                    android:textSize="13sp"
                    android:textColor="@color/hg_muted"
                    android:layout_marginStart="22dp"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/paymentHistoryTitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- ✅ Payment list -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/paymentRecycler"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="18dp"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    app:layout_constraintTop_toBottomOf="@id/paymentHistorySubtitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Drawer menu -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"

        android:background="@color/hg_surface"
        app:menu="@menu/drawer_menu"
        app:itemIconTint="@color/hg_onSurface"
        app:itemTextColor="@color/hg_onSurface"
        app:itemBackground="@drawable/drawer_item_bg" />

</androidx.drawerlayout.widget.DrawerLayout>
