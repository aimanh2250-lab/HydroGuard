<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="160dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/hg_surface"
    app:cardCornerRadius="18dp"
    app:cardElevation="8dp"
    app:strokeColor="@color/hg_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <!-- Top row: icon + name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgCategoryIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="Category icon"
                android:src="@drawable/ic_device"
                app:tint="@color/hg_primary" />

            <TextView
                android:id="@+id/tvCategoryName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Shower"
                android:textColor="@color/hg_onSurface"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Liters used (chip-like) -->
        <com.google.android.material.chip.Chip
            android:id="@+id/tvCategoryLiters"
            style="@style/Widget.Material3.Chip.Assist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="120.5 L"
            android:textStyle="bold"
            android:textColor="@color/hg_primary"
            app:chipBackgroundColor="@color/hg_primaryContainer"
            app:chipStrokeColor="@color/hg_outline"
            app:chipStrokeWidth="1dp"
            app:chipIcon="@drawable/ic_flow"
            app:chipIconVisible="true"
            app:chipMinHeight="34dp"
            app:iconStartPadding="10dp"
            app:textStartPadding="6dp"
            app:textEndPadding="12dp" />

        <!-- Small hint text -->
        <TextView
            android:id="@+id/tvCategoryHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="This month"
            android:textColor="@color/hg_muted"
            android:textSize="12sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
