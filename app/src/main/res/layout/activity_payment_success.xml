<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ✅ Background Image (same as other pages) -->
    <ImageView
        android:id="@+id/ivAnimatedBg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.95"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_motion_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarSuccess"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:title="Receipt"
        app:titleTextColor="@color/hg_onSurface"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/receiptCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginTop="18dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/hg_outline"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarSuccess"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Successful ✅"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/hg_onSurface"/>

            <TextView
                android:id="@+id/tvReceipt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Receipt: -"
                android:textColor="@color/hg_muted"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/tvMethod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Method: -"
                android:layout_marginTop="6dp"
                android:textColor="@color/hg_onSurface"/>

            <TextView
                android:id="@+id/tvMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Month: -"
                android:layout_marginTop="6dp"
                android:textColor="@color/hg_onSurface"/>

            <TextView
                android:id="@+id/tvUsage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usage: -"
                android:layout_marginTop="6dp"
                android:textColor="@color/hg_onSurface"/>

            <TextView
                android:id="@+id/tvAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Amount: RM 0.00"
                android:textStyle="bold"
                android:textColor="@color/hg_primary"
                android:layout_marginTop="10dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackToBilling"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Back to Billing"
        android:textStyle="bold"
        app:cornerRadius="14dp"
        app:backgroundTint="@color/hg_primary"
        android:textColor="@color/hg_onPrimary"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="22dp"
        app:layout_constraintTop_toBottomOf="@id/receiptCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
