<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A3D62">

    <!-- 🌊 REAL WATER SPLASH (LOTTIE) -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/waterSplash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        app:lottie_rawRes="@raw/hydroguard_splash"
        app:lottie_autoPlay="false"
        app:lottie_loop="false" />

    <!-- 🧭 CONTENT ABOVE WATER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_hydroguard_logo"
            android:alpha="0"/>

        <TextView
            android:layout_marginTop="16dp"
            android:text="HydroGuard"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:layout_marginTop="4dp"
            android:text="Monitoring Water. Protecting Tomorrow."
            android:textSize="14sp"
            android:textColor="#CCFFFFFF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

</FrameLayout>
